import { useEffect, useMemo, useState } from "react";

const TASK_SHEET_URL = "PASTE_YOUR_TASK_GOOGLE_SHEET_LINK_HERE";
const TRADESHOW_EMBED_URL = "PASTE_TRADESHOW_EMBED_LINK_HERE";
const COOP_EMBED_URL = "PASTE_COOP_EMBED_LINK_HERE";
const DEALER_DIRECTORY_EMBED_URL = "PASTE_DEALER_DIRECTORY_EMBED_LINK_HERE";
const SMALL_SALES_ORDERS_EMBED_URL = "PASTE_SMALL_SALES_ORDERS_EMBED_LINK_HERE";

function sheetToCsvUrl(url) {
  if (!url) return "";
  if (url.includes("format=csv") || url.includes("output=csv")) return url;

  const idMatch = url.match(/\/spreadsheets\/d\/([a-zA-Z0-9-_]+)/);
  const gidMatch = url.match(/gid=([0-9]+)/);

  if (!idMatch) return url;

  return `https://docs.google.com/spreadsheets/d/${idMatch[1]}/export?format=csv&gid=${
    gidMatch ? gidMatch[1] : "0"
  }`;
}

function parseCSV(text) {
  const rows = text.trim().split("\n");
  const headers = rows[0].split(",").map((h) => h.trim());

  return rows
    .slice(1)
    .map((row) => {
      const values = row.split(",").map((v) => v.trim());
      return headers.reduce((obj, header, i) => {
        obj[header] = values[i] || "";
        return obj;
      }, {});
    })
    .filter((task) => String(task.Task || "").trim() !== "");
}

function isCompleted(task) {
  const completedValue = String(
    task["Completed?"] ||
      task.Completed ||
      task.Complete ||
      task.Done ||
      task.Status ||
      ""
  )
    .trim()
    .toLowerCase();

  return [
    "true",
    "yes",
    "y",
    "done",
    "complete",
    "completed",
    "checked",
    "✓",
    "✔",
  ].includes(completedValue);
}

async function fetchTasks(url) {
  if (!url || !url.includes("http")) return [];

  const res = await fetch(sheetToCsvUrl(url));
  const text = await res.text();

  if (text.includes("<html")) {
    console.error("Sheet is not public or not CSV");
    return [];
  }

  return parseCSV(text);
}

export default function SouthCommandCenter() {
  const [tasks, setTasks] = useState([]);
  const [search, setSearch] = useState("");
  const [responsibleFilter, setResponsibleFilter] = useState("All");

  const [tasksOpen, setTasksOpen] = useState(true);
  const [tradeshowsOpen, setTradeshowsOpen] = useState(false);
  const [coopOpen, setCoopOpen] = useState(false);
  const [dealerDirectoryOpen, setDealerDirectoryOpen] = useState(false);
  const [smallSalesOrdersOpen, setSmallSalesOrdersOpen] = useState(false);

  useEffect(() => {
    fetchTasks(TASK_SHEET_URL).then(setTasks);
  }, []);

  const completedTasks = tasks.filter(isCompleted);
  const openTasks = tasks.filter((t) => !isCompleted(t));

  const responsibleOptions = useMemo(() => {
    const names = openTasks
      .map(
        (t) =>
          t.Responsible ||
          t.Owner ||
          t.Assigned ||
          t["Assigned To"] ||
          ""
      )
      .filter(Boolean);

    return ["All", ...Array.from(new Set(names))];
  }, [openTasks]);

  const filteredTasks = useMemo(() => {
    return openTasks.filter((task) => {
      const text = Object.values(task).join(" ").toLowerCase();

      const responsible =
        task.Responsible ||
        task.Owner ||
        task.Assigned ||
        task["Assigned To"] ||
        "";

      return (
        text.includes(search.toLowerCase()) &&
        (responsibleFilter === "All" || responsible === responsibleFilter)
      );
    });
  }, [openTasks, search, responsibleFilter]);

  const progress =
    tasks.length > 0
      ? Math.round((completedTasks.length / tasks.length) * 100)
      : 0;

  return (
    <main className="east-page">
      <div className="east-shell">
        <div className="east-top">
          <div>
            <p className="eyebrow">GOOGLE SHEET SYNC</p>
            <h1>South Command Center</h1>
            <p className="subtitle">
              South territory operations, tracking, and execution pulled from Google Sheets.
            </p>
          </div>

          <div className="progress-card">
            <p>Progress</p>
            <strong>{progress}%</strong>
          </div>
        </div>

        <div className="stats-grid">
          <StatCard label="Total Tasks" value={tasks.length} />
          <StatCard label="Open Tasks" value={openTasks.length} />
          <StatCard label="Completed" value={completedTasks.length} />
          <StatCard label="Showing" value={filteredTasks.length} />
        </div>

        <section className="filters-card">
          <div>
            <h3>Filters</h3>
            <p>Only open tasks are shown.</p>
          </div>

          <div className="filters-right">
            <input
              value={search}
              onChange={(e) => setSearch(e.target.value)}
              placeholder="Search..."
            />

            <select
              value={responsibleFilter}
              onChange={(e) => setResponsibleFilter(e.target.value)}
            >
              {responsibleOptions.map((name) => (
                <option key={name}>{name}</option>
              ))}
            </select>
          </div>
        </section>

        <SheetEmbedCard title="Tradeshows" open={tradeshowsOpen} setOpen={setTradeshowsOpen} url={TRADESHOW_EMBED_URL} />
        <SheetEmbedCard title="Co-op Spend" open={coopOpen} setOpen={setCoopOpen} url={COOP_EMBED_URL} />
        <SheetEmbedCard title="Dealer Directory" open={dealerDirectoryOpen} setOpen={setDealerDirectoryOpen} url={DEALER_DIRECTORY_EMBED_URL} />
        <SheetEmbedCard title="Small Sales Orders" open={smallSalesOrdersOpen} setOpen={setSmallSalesOrdersOpen} url={SMALL_SALES_ORDERS_EMBED_URL} />

        <CollapsibleCard
          title="South Task List"
          subtitle={`${filteredTasks.length} open tasks`}
          open={tasksOpen}
          setOpen={setTasksOpen}
        >
          <TaskTable rows={filteredTasks} />
        </CollapsibleCard>
      </div>
    </main>
  );
}

function StatCard({ label, value }) {
  return (
    <div className="stat-card">
      <p>{label}</p>
      <strong>{value}</strong>
    </div>
  );
}

function CollapsibleCard({ title, subtitle, open, setOpen, children }) {
  return (
    <div className="card">
      <div className="card-header" onClick={() => setOpen(!open)}>
        <div>
          <h3>{title}</h3>
          <p>{subtitle}</p>
        </div>
        <span>{open ? "Close" : "Open"}</span>
      </div>
      {open && <div>{children}</div>}
    </div>
  );
}

function SheetEmbedCard({ title, open, setOpen, url }) {
  return (
    <CollapsibleCard title={title} subtitle="" open={open} setOpen={setOpen}>
      <iframe style={{ width: "100%", height: 500 }} src={url} />
    </CollapsibleCard>
  );
}

function TaskTable({ rows }) {
  if (!rows.length) return <p>No open tasks</p>;

  const headers = Object.keys(rows[0]).filter((h) =>
    ["Task", "Dealer", "Responsible", "Due Date"].includes(h)
  );

  return (
    <table>
      <thead>
        <tr>{headers.map((h) => <th key={h}>{h}</th>)}</tr>
      </thead>
      <tbody>
        {rows.map((row, i) => (
          <tr key={i}>
            {headers.map((h) => <td key={h}>{row[h]}</td>)}
          </tr>
        ))}
      </tbody>
    </table>
  );
}
